[fetch]
	prune = true

[user]
	name = "Jan Oehen"
	email = "jan.oe.hen@live.com"

[core]
	excludesfile = ~/.gitignore
	editor = code --wait

[push]
	default = current

[pull]
	rebase = true

[init]
	defaultBranch = main

[log]
	date = format:%d %b %y

[alias]
	lg = log --oneline --graph --decorate --all
	st = status -sb
